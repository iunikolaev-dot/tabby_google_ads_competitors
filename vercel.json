{
  "buildCommand": null,
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" }
      ]
    }
  ],
  "functions": {
    "api/ads.py": {
      "includeFiles": "data/**",
      "memory": 512,
      "maxDuration": 10
    },
    "api/cost.py": {
      "includeFiles": "metrics/**",
      "memory": 512,
      "maxDuration": 15
    }
  }
}
