.DS_Store
.claude/
__pycache__/
*.pyc
*.log
debug_responses/
.vercel
.env
.env*.local

# Scraper output / large data artifacts
bq_results.json
targeted_scrape_results.json
firecrawl_fresh_scrape.json
embed_urls.json
backups/
staging/
# Per-run summaries are noisy; only the spend ledger is needed at runtime
# (api/cost.py reads it). Can't use `metrics/` + `!file` carve-outs because
# git won't recurse into ignored directories.
metrics/run_*.json
logs/

# Downloaded media (regenerable, large)
public/meta_images/
public/google_videos/
public/screenshots/

# SQLite ephemeral files (the .db itself IS committed — that's the SoT)
data/*.db-wal
data/*.db-shm
data/*.db-journal

# Personal notes
OpenAI ad analysis prompt.rtf
