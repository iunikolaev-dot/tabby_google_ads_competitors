# Python code — not needed for static site serving
*.py
*.pyc
__pycache__/
_deprecated/
backups/
staging/
logs/
# api/cost.py reads metrics/spend_history.jsonl at runtime; don't ignore.
# Per-run summaries are unused at runtime so we strip them.
metrics/run_*.json
v2/
debug_responses/
debug_firecrawl/

# EXCEPT: serverless function code that Vercel actually runs.
# api/*.py is the function entry; pipeline/sqlite_store.py won't be imported
# by api/ads.py (function is self-contained), but we keep it un-ignored in
# case future functions want it.
!api/*.py
!pipeline/sqlite_store.py

# Data files that aren't served
*.json
!vercel.json
*.log
*.rtf

# Git and config
.git/
.gitignore
.claude/
.env
.env*.local

# Large media already cached on Vercel CDN — uncomment if re-uploading
# public/meta_images/
# public/google_videos/
